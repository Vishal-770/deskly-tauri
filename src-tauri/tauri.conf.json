{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deskly",
  "version": "5.0.0",
  "identifier": "com.deskly.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Deskly",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },

  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI1NTFEODM4QUI5N0JBODEKUldTQnVwZXJPTmhSdFRmR3BVYms1QmJ1Z0JETk1yRzkyZ2tYaXRNT1JUUFhNTy8xNWpwMEhjLzUK",
      "endpoints": [
        "https://github.com/Vishal-770/deskly-tauri/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
